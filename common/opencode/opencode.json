{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "godoc": {
      "type": "local",
      "command": ["godoc-mcp"],
      "enabled": true,
    },
    "gopls": {
      "type": "local",
      "command": ["gopls", "mcp"],
      "enabled": true,
    },
    "diffmcp": {
      "type": "local",
      "command": ["diffmcp", "mcp"],
      "enabled": true,
    },
    "Glean": {
      "type": "remote",
      "url": "https://cockroachlabs-be.glean.com/mcp/christian-glean",
      "oauth": {}
    }
  },
  "agent": {},
  "plugin": ["@franlol/opencode-md-table-formatter"]
}
